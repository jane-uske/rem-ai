{
  "name": "rem-ai",
  "version": "1.0.0",
  "description": "这是 Rem AI 项目。",
  "main": "dist/server/server.js",
  "scripts": {
    "dev": "nodemon --watch server --exec ts-node server/server.ts",
    "restart": "lsof -i :3000 -t | xargs kill 2>/dev/null; sleep 1; nodemon --watch server --exec ts-node server/server.ts",
    "build": "npm run build --prefix web && tsc",
    "typecheck": "tsc --noEmit",
    "start": "NODE_ENV=production node dist/server/server.js",
    "web:dev": "npm run dev --prefix web",
    "web:build": "npm run build --prefix web"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "dotenv": "^17.4.0",
    "ioredis": "^5.10.1",
    "jsonwebtoken": "^9.0.3",
    "next": "^15.5.14",
    "node-edge-tts": "^1.2.10",
    "openai": "^6.33.0",
    "pg": "^8.20.0",
    "pino": "^10.3.1",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "ws": "^8.20.0"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^25.5.0",
    "@types/pg": "^8.20.0",
    "@types/ws": "^8.18.1",
    "pino-pretty": "^13.1.3",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.2"
  }
}
