{
  "name": "rem-companion-ai",
  "version": "1.0.0",
  "private": true,
  "description": "这是 Rem Companion AI 项目。",
  "main": "dist/server/server.js",
  "workspaces": [
    "web"
  ],
  "scripts": {
    "dev": "nodemon --legacy-watch --watch server --exec ts-node server/server.ts",
    "dev:once": "ts-node server/server.ts",
    "dev:native": "./scripts/start-native-dev.sh",
    "dev:web:clean": "./scripts/clean-web-cache.sh",
    "dev:check": "./scripts/check-local-dev.sh",
    "dev:term": "./scripts/start-web-terminal.sh",
    "dev:term:check": "./scripts/check-web-terminal.sh",
    "tunnel:start": "./scripts/start-cloudflare-tunnel.sh",
    "restart": "lsof -i :3000 -t | xargs kill 2>/dev/null; sleep 1; nodemon --legacy-watch --watch server --exec ts-node server/server.ts",
    "dev:infra:start": "./scripts/start-dev-stack.sh",
    "dev:infra:ide": "./scripts/start-dev-stack.sh --ide",
    "dev:stack:start": "./scripts/start-dev-stack.sh --app",
    "dev:stack:ide": "./scripts/start-dev-stack.sh --ide",
    "dev:stack:stop": "./scripts/stop-dev-stack.sh",
    "dev:stack:bootstrap": "./scripts/bootstrap-home-dev.sh",
    "build": "npm run build --prefix web && tsc",
    "test": "mocha --require ts-node/register/transpile-only \"test/**/*.test.ts\"",
    "typecheck": "tsc --noEmit",
    "start": "NODE_ENV=production node dist/server/server.js",
    "web:dev": "npm run dev --prefix web",
    "web:build": "npm run build --prefix web"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "dotenv": "^17.4.0",
    "ioredis": "^5.10.1",
    "jsonwebtoken": "^9.0.3",
    "next": "^15.5.14",
    "node-edge-tts": "^1.2.10",
    "openai": "^6.33.0",
    "pg": "^8.20.0",
    "pino": "^10.3.1",
    "ws": "^8.20.0"
  },
  "devDependencies": {
    "@types/chai": "^5.2.3",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/mocha": "^10.0.10",
    "@types/node": "^25.5.0",
    "@types/pg": "^8.20.0",
    "@types/ws": "^8.18.1",
    "chai": "^6.2.2",
    "mocha": "^11.7.5",
    "nodemon": "^3.1.10",
    "pino-pretty": "^13.1.3",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.2"
  }
}
