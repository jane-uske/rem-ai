{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "lib": ["ES2020"],
    "outDir": "./dist",
    "rootDir": ".",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true
  },
  "include": ["server/**/*", "agents/**/*", "memory/**/*", "emotion/**/*", "brain/**/*", "brains/**/*", "voice/**/*", "llm/**/*", "utils/**/*", "storage/**/*", "avatar/**/*", "infra/**/*"],
  "exclude": ["node_modules", "dist"]
}
