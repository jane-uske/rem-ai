# === LLM ===
key=
base_url=
model=

# === TTS ===
tts_provider=edge
# 二次元推荐: zh-CN-XiaoyiNeural (晓伊, 年轻可爱)
# 成熟女声: zh-CN-XiaoxiaoNeural (晓晓, 自然知性)
# 温柔女声: zh-CN-XiaomoNeural  (晓墨, 温柔)
tts_voice=zh-CN-XiaoyiNeural
tts_lang=zh-CN
tts_rate=default
# tts_pitch=+3Hz    # 提高音调更二次元，可选 +1Hz ~ +8Hz
tts_max_chars=120
# edge_tts_timeout=10000
# tts_key=          # for openai provider
# tts_base_url=     # for openai provider
# tts_model=tts-1   # for openai provider
# piper_model=      # for piper provider
# piper_cmd=piper
# piper_speaker=
# piper_length_scale=
# piper_noise_scale=
# piper_noise_w_scale=
# piper_timeout=10000

# === STT ===
stt_provider=openai
# stt_key=
# stt_base_url=
# stt_model=whisper-1
# whisper_model=
# whisper_lang=zh
# whisper_cmd=whisper-cli
# whisper_prompt=以下是普通话的句子。
# whisper_extra_args=
# 中文识别建议使用 ggml-medium.bin 或 ggml-large-v3.bin，base 模型中文效果很差
# 下载: https://huggingface.co/ggerganov/whisper.cpp/tree/main

# === Web (Next.js) ===
# NEXT_PUBLIC_WS_URL=

# === Storage ===
# DATABASE_URL=postgresql://rem:rem_password@localhost:5432/rem_ai
# REDIS_URL=redis://localhost:6379

# === Auth ===
# JWT_SECRET=

# === Logging ===
# LOG_LEVEL=info

# === VAD ===
# VAD 能量阈值 (0-1)，默认 0.055，值越大越不容易误触发
# VAD_THRESHOLD=0.055
# 触发语音开始所需的最小帧数（每帧约50ms），默认 5（约250ms）
# VAD_MIN_SPEECH_FRAMES=5
# 判定语音结束所需的静默帧数，默认 14（约700ms）
# VAD_SILENCE_FRAMES=14
# 最大过零率 (0-1)，默认 0.45
# VAD_MAX_ZCR=0.45
# 峰值因子 peak/RMS 上限，默认 22；键盘敲击等脉冲噪声通常远大于 22
# VAD_MAX_CREST=22

# === Server ===
# NODE_ENV=development
# PORT=3000
