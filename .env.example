# === LLM ===
key=
base_url=
model=

# === TTS ===
tts_provider=edge
# 二次元推荐: zh-CN-XiaoyiNeural (晓伊, 年轻可爱)
# 成熟女声: zh-CN-XiaoxiaoNeural (晓晓, 自然知性)
# 温柔女声: zh-CN-XiaomoNeural  (晓墨, 温柔)
tts_voice=zh-CN-XiaoyiNeural
tts_lang=zh-CN
tts_rate=default
# tts_pitch=+3Hz    # 提高音调更二次元，可选 +1Hz ~ +8Hz
tts_max_chars=120
# 默认去掉（）与 () 里的舞台说明再送 TTS；设为 0 则连括号一起朗读
# tts_strip_parenthetical=0
# 默认去掉 emoji 再送 TTS；设为 0 保留（部分引擎会读名称或异常）
# tts_strip_emoji=0
# 短句缓存（S10）：仅缓存 normalize 后长度不超过下列值的合成结果
# tts_cache_max_chars=24
# tts_cache_max_entries=80
# Edge TTS 连接池（M7）：同音色/韵律复用一条 WebSocket；异常可 edge_tts_pool=0 回退为每句新连接
# edge_tts_pool_idle_ms=45000
# edge_tts_pool=0
# edge_tts_timeout=10000
# tts_key=          # for openai provider
# tts_base_url=     # for openai provider
# tts_model=tts-1   # for openai provider
# piper_model=      # for piper provider
# piper_cmd=piper
# piper_speaker=
# piper_length_scale=
# piper_noise_scale=
# piper_noise_w_scale=
# piper_timeout=10000

# === STT ===
stt_provider=openai
# stt_key=
# stt_base_url=
# stt_model=whisper-1
# OpenAI 兼容转写：以下可选；不填则与改前一致（仅 model + file），兼容性最好
# stt_language=zh
# stt_temperature=0
# stt_prompt=以下是普通话口语对话。
# whisper_model=
# whisper_lang=zh
# whisper_cmd=whisper-cli
# whisper_prompt=以下是普通话的句子。
# whisper_extra_args=
# 中文识别建议使用 ggml-medium.bin 或 ggml-large-v3.bin，base 模型中文效果很差
# 下载: https://huggingface.co/ggerganov/whisper.cpp/tree/main

# === Web (Next.js) ===
# 可选：根目录一体 `npm run dev` / `npm start` 时传给 Next 的主机名（默认 localhost）。勿写端口：错误示例 REM_NEXT_HOSTNAME=localhost:3000；可写完整 URL：REM_NEXT_HOSTNAME=https://rem.example.com
# REM_NEXT_HOSTNAME=localhost
# 仅跑「npm run web:dev」而后端在 3000 时必配；代码已对 3001/3002 自动指向 :3000/ws。须含 ws:// 或 wss://，勿只写 localhost:3000/ws（会被当成相对路径导致地址栏嵌套 /localhost:3000/...）
# NEXT_PUBLIC_WS_URL=ws://127.0.0.1:3000/ws
# 可选：网页 3D 角色 VRM（文件放 web/public/vrm/；不设则代码默认 1497262518610234440.vrm）。勿写空值 NEXT_PUBLIC_VRM_URL=
# NEXT_PUBLIC_VRM_URL=/vrm/1497262518610234440.vrm
# 默认朝向已按「面向镜头」处理；若你的模型仍背对镜头，可设 NEXT_PUBLIC_VRM_YAW=3.14159
# 取景：不设或 full=全身（默认偏靠画面下方）；upper=上半身特写（拉近，腿部多在画外）。画布可右键/中键拖动平移、左键旋转、滚轮缩放
# NEXT_PUBLIC_VRM_FRAMING=full
# NEXT_PUBLIC_VRM_FRAMING=upper
# 默认禁用 VRMC_node_constraint（否则会每帧把手拉回模型预设姿势，单手高举落不下来）。若头发/饰品异常可设为 0 恢复约束
# NEXT_PUBLIC_VRM_DISABLE_NODE_CONSTRAINT=0

# === Storage ===
# DATABASE_URL=postgresql://rem:rem_password@localhost:5432/rem_ai
# REDIS_URL=redis://localhost:6379

# === Auth ===
# JWT_SECRET=

# === Logging ===
# LOG_LEVEL=info

# === VAD ===
# VAD 能量阈值 (0-1)，默认约 0.06；误触发多就略调高，说话没反应就略调低
# VAD_THRESHOLD=0.06
# 触发语音开始所需的最小帧数（每帧约50ms），默认 6（约300ms）
# VAD_MIN_SPEECH_FRAMES=6
# 判定语音结束所需的静默帧数（每帧=一次上行 chunk，约 40–50ms），默认 10（约 0.5s）
# 说完后仍要等这么久才 speech_end；太短会切断句子，太长体感「识别结束慢」
# VAD_SILENCE_FRAMES=10
# 句首预录：speech_start 前保留最近多少 ms 的 PCM 拼进识别（防丢前几个字）
# VAD_PRE_ROLL_MS=480
# speech_end 后等待多少 ms 再送 STT；若在这段时间内再次 speech_start，合并为一句（防一句拆多条）
# 设为 0 则 speech_end 立即识别（句中停顿易拆成多条消息）
# VAD_UTTERANCE_GAP_MS=420
# 默认启用自适应：已说时长越长 merge 窗口越长（长句换气）、越短则延迟越短（短句更快落字）
# VAD_UTTERANCE_GAP_ADAPTIVE=0   # 设为 0 则只用上面固定 VAD_UTTERANCE_GAP_MS
# VAD_UTTERANCE_GAP_MIN_MS=300   # 短句侧延迟（ms）
# VAD_UTTERANCE_GAP_MAX_MS=780   # 长句侧 merge 窗口（ms）
# VAD_UTTERANCE_GAP_ADAPTIVE_LO_MS=400   # 低于约此时长 → 贴近 MIN
# VAD_UTTERANCE_GAP_ADAPTIVE_HI_MS=4400  # 高于约此时长 → 贴近 MAX
# 最大过零率 (0-1)，默认 0.45
# VAD_MAX_ZCR=0.45
# 峰值因子 peak/RMS 上限，默认 22；键盘敲击等脉冲噪声通常远大于 22
# VAD_MAX_CREST=22

# === TTS chunking（逐句合成） ===
# 首句无句号时至少攒够字数再合成；无句号的长句按此长度切开
# TTS_CHUNK_MIN_CHARS=48
# TTS_CHUNK_MAX_CHARS=120
# 少于该字数的片段不单独送 TTS，会与下一段合并（避免「哇！」单独播完再等很久）；流结束仍播剩余短句
# TTS_MIN_CHARS=16

# === Brain / Pipeline ===
# 注入 LLM 的对话历史估算 token 上限（约 中文 1.35 字/token）
# MAX_HISTORY_TOKENS=2600
# 在 LLM 与逐句 TTS 并行开始前，异步合成短「嗯」填充等待（需开启 TTS）
# rem_thinking_filler=1
# 用户多久无消息则服务端触发 Rem 主动搭话（毫秒，0=关闭）
# REM_SILENCE_NUDGE_MS=45000
# 至少聊过多少轮才允许沉默搭话（默认 2）
# REM_SILENCE_NUDGE_MIN_TURNS=2

# === Server ===
# NODE_ENV=development
# HTTP 监听端口（gateway 与 Next 共用；默认 3000）
# PORT=3000
